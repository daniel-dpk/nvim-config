snippet pytest "Pytest test file template"
	# pylint: disable=missing-module-docstring,missing-function-docstring
	# pylint: disable=missing-class-docstring

	from __future__ import annotations

	from pytest import approx
	import numpy as np
	from numpy import array

	from ${1:`expand("%:p:h:h")`}.${2:`substitute(expand("%:t:r"), "^test_", "", "")`} import ${3:SomeClass}


	class Test$2:
		def test_$3(self):
			assert array([1]) == approx(array([0])) # fail to show tests work


