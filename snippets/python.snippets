snippet roprop "Read-only Property"
	@property
	def ${1:my_prop}(self):
		return self.${2:_$1}

snippet rwprop "Read/Write Property"
	@property
	def ${1:my_prop}(self):
		return self.${2:_$1}
	@$1.setter
	def $1(self, value):
		self.$2 = value

snippet lprop "Lazy Read-only Property"
	@property
	def ${1:my_prop}(self):
		if self.${2:_$1} is None:
			self.$2 = self.${3:_compute_$1}()
		return self.$2

snippet lwprop "Lazy Read/Write Property"
	@property
	def ${1:my_prop}(self):
		if self.${2:_$1} is None:
			self.$2 = self.${3:_compute_$1}
		return self.$2
	@$1.setter
	def $1(self, value):
		self.$2 = value

